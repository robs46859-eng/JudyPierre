# Server-only AI Studio authorization key. Never expose this as a VITE_ variable.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.5-flash"

# Hermes translation service. The worker submits POST /v1/jobs and polls
# GET /v1/jobs/:jobId. Set the token only when the gateway requires it.
HERMES_GATEWAY_URL=""
HERMES_BEARER_TOKEN=""
HERMES_POLL_INTERVAL_MS="2000"
HERMES_REQUEST_TIMEOUT_MS="15000"
HERMES_MAX_ATTEMPTS="90"
HERMES_JOB_TIMEOUT_MS="600000"

# Durable request state and completion logs. Mount this path to persistent
# storage in production.
JUDY_DATA_DIR="./data"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=""
